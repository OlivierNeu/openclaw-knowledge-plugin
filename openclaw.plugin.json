{
  "id": "openclaw-knowledge",
  "name": "Qdrant Knowledge Base",
  "description": "Query multiple Qdrant collections and inject relevant documents into agent context before each turn",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "geminiApiKey": {
        "type": "string",
        "description": "Gemini API key for embedding queries"
      },
      "qdrantUrl": {
        "type": "string",
        "description": "Qdrant server URL"
      },
      "qdrantApiKey": {
        "type": "string",
        "description": "Qdrant API key"
      },
      "collections": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Qdrant collections to search"
      },
      "topK": {
        "type": "number",
        "description": "Max results per collection (default: 5)"
      },
      "scoreThreshold": {
        "type": "number",
        "description": "Min similarity score 0-1 (default: 0.3)"
      },
      "maxInjectChars": {
        "type": "number",
        "description": "Max characters to inject into prompt (default: 4000)"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable/disable knowledge injection (default: true)"
      }
    },
    "required": ["geminiApiKey", "qdrantUrl", "collections"]
  },
  "uiHints": {
    "geminiApiKey": {
      "label": "Gemini API Key",
      "sensitive": true,
      "help": "Use ${GEMINI_API_KEY} for env var substitution"
    },
    "qdrantApiKey": {
      "label": "Qdrant API Key",
      "sensitive": true,
      "help": "Use ${QDRANT_API_KEY} for env var substitution"
    },
    "collections": {
      "label": "Collections to search",
      "help": "List of Qdrant collection names (e.g. knowledge_olivier, knowledge_business)"
    },
    "enabled": {
      "label": "Auto-inject knowledge",
      "help": "Automatically search and inject relevant documents before each agent turn"
    }
  }
}
